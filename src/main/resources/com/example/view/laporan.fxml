<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.LaporanController">
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Dari" />
        <DatePicker fx:id="fromPicker" />
        <Label text="Sampai" />
        <DatePicker fx:id="toPicker" />
        <Button onAction="#handleTerapkan" styleClass="primary-button" text="Terapkan" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox spacing="10">
        <VBox spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
            <Label styleClass="summary-card-label" text="TOTAL SALES" />
            <Label fx:id="totalSalesLabel" styleClass="summary-card-value" text="Rp 0" />
        </VBox>
        <VBox spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
            <Label styleClass="summary-card-label" text="TRANSAKSI" />
            <Label fx:id="jumlahTrxLabel" styleClass="summary-card-value" text="0" />
        </VBox>
        <VBox spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
            <Label styleClass="summary-card-label" text="TOTAL PROFIT" />
            <Label fx:id="totalProfitLabel" styleClass="summary-card-value" text="Rp 0" />
        </VBox>
        <VBox spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
            <Label styleClass="summary-card-label" text="BEST SELLER" />
            <Label fx:id="bestSellerLabel" styleClass="summary-card-value" text="-" wrapText="true" />
        </VBox>
    </HBox>

    <TableView fx:id="trxTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="160" text="ID Transaksi" />
            <TableColumn fx:id="colTanggal" prefWidth="160" text="Tanggal" />
            <TableColumn fx:id="colKasir" prefWidth="120" text="Kasir" />
            <TableColumn fx:id="colItems" prefWidth="80" text="# Item" />
            <TableColumn fx:id="colTotal" prefWidth="120" text="Total" />
            <TableColumn fx:id="colMetode" prefWidth="100" text="Metode" />
        </columns>
    </TableView>
</VBox>
